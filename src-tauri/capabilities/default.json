{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "sh",
          "cmd": "sh",
          "args": [
            "-c",
            {
              "validator": ".*"
            }
          ]
        }
      ]
    },
    "shell:allow-kill",
    "fs:allow-read-dir",
    "fs:allow-remove",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "bin/yt-dlp",
          "sidecar": true,
          "args": true
        },
        {
          "name": "bin/ffmpeg",
          "sidecar": true,
          "args": true
        },
        {
          "name": "bin/ffprobe",
          "sidecar": true,
          "args": true
        }
      ]
    },
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        {
          "path": "$DOWNLOAD"
        },
        {
          "path": "$DOWNLOAD/**"
        }
      ]
    }
  ]
}